# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Google OAuth (si se usa login con Google)
CLIENT_ID=
CLIENT_SECRET=

# App
PORT=3016
PASSRAMDOM=
JWT_SECRET=

# Email (Nodemailer)
# EMAIL_PROVIDER: gmail | outlook  (default: gmail)
EMAIL_PROVIDER=gmail
# USER_EMAIL: la cuenta de correo desde la que se envían los emails
USER_EMAIL=
# PASSWORD_EMAIL:
#   Gmail   -> App Password (16 chars, sin espacios). Requiere 2FA activo.
#              Generar en: https://myaccount.google.com/apppasswords
#   Outlook -> App Password si la cuenta tiene MFA activo.
#              Generar en: https://account.microsoft.com/security > Opciones avanzadas > Contraseñas de aplicación
#              Si NO tiene MFA, usar la contraseña normal de la cuenta Microsoft.
PASSWORD_EMAIL=
# EMAILS_ENABLED: true | false  (false desactiva el envío sin cambiar código)
EMAILS_ENABLED=true

# OpenAI
OPENAI_API_KEY=

# AWS S3
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# DNS (requerido en algunos entornos para resolver hosts externos)
NODE_DNS_SERVERS=8.8.8.8,1.1.1.1

# GitHub Personal Access Token (si se usa alguna integración con GitHub)
GHP_TOKEN=

<!DOCTYPE html>
<html lang="es">
<head><meta charset="UTF-8"><title>Reembolso Directo Pagado</title></head>
<body style="font-family:Arial,sans-serif;color:#333;max-width:600px;margin:0 auto">
  <img src="{{logoUrl}}" alt="Viatika" style="height:40px;margin:20px 0">
  <h2 style="color:#276749">Pago de Reembolso Directo Registrado</h2>
  <p>Estimado/a <strong>{{recipientName}}</strong>,</p>
  <p>Se ha registrado el pago de tu reembolso directo.</p>
  <table style="width:100%;border-collapse:collapse;margin:16px 0">
    <tr><td style="padding:8px;background:#f7f7f7;font-weight:bold">Codigo</td><td style="padding:8px">{{code}}</td></tr>
    <tr><td style="padding:8px;background:#f7f7f7;font-weight:bold">Monto pagado</td><td style="padding:8px">S/ {{amount}}</td></tr>
  </table>
  <p><a href="{{receiptUrl}}" style="color:#2b6cb0">Ver comprobante de pago</a></p>
  <p style="color:#718096;font-size:12px">© {{year}} Viatika</p>
</body>
</html>

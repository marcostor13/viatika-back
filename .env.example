# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Google OAuth (si se usa login con Google)
CLIENT_ID=
CLIENT_SECRET=

# App
PORT=3016
PASSRAMDOM=
JWT_SECRET=

# Email (Nodemailer)
USER_EMAIL=
PASSWORD_EMAIL=

# OpenAI
OPENAI_API_KEY=

# AWS S3
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2

# DNS (requerido en algunos entornos para resolver hosts externos)
NODE_DNS_SERVERS=8.8.8.8,1.1.1.1

# GitHub Personal Access Token (si se usa alguna integración con GitHub)
GHP_TOKEN=

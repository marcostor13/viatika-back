<!DOCTYPE html>
<html lang='es'>
<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>Viatico aprobado - Pendiente de pago</title>
  <style>
    body { margin: 0; padding: 0; background: #f5f7fb; font-family: Arial, sans-serif; color: #1f2937; }
    .wrap { padding: 24px 12px; }
    .card { max-width: 640px; margin: 0 auto; background: #ffffff; border-radius: 14px; overflow: hidden; border: 1px solid #e5e7eb; }
    .head { padding: 24px; text-align: center; border-bottom: 1px solid #f1f5f9; }
    .head img { max-height: 38px; }
    .content { padding: 24px; }
    .title { margin: 0 0 12px; font-size: 20px; color: #0f172a; }
    .muted { color: #64748b; font-size: 14px; margin: 0 0 18px; }
    .box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 14px; margin: 14px 0; }
    .box-title { font-size: 13px; font-weight: 700; color: #374151; margin: 0 0 10px; text-transform: uppercase; letter-spacing: 0.04em; }
    .row { margin: 6px 0; font-size: 14px; }
    .badge { display: inline-block; background: #dbeafe; color: #1e40af; border-radius: 6px; padding: 2px 10px; font-size: 13px; font-weight: 700; margin-bottom: 12px; }
    .amount { font-size: 22px; font-weight: 800; color: #1d4ed8; margin: 4px 0 12px; }
    .footer { padding: 16px 24px; text-align: center; font-size: 12px; color: #94a3b8; border-top: 1px solid #f1f5f9; }
    .no-account { color: #94a3b8; font-style: italic; }
    .urgent { background-color: #fef2f2; border-left: 6px solid #dc2626; border-radius: 8px; padding: 12px 16px; margin: 0 0 16px; font-weight: 600; color: #991b1b; font-size: 14px; }
  </style>
</head>
<body>
  <div class='wrap'>
    <div class='card'>
      <div class='head'>
        {{#if logoUrl}}<img src='{{logoUrl}}' alt='Viatika' />{{/if}}
      </div>
      <div class='content'>
        {{#if urgent}}
        <div class='urgent'>{{urgentBanner}}</div>
        {{/if}}
        <span class='badge'>Viatico aprobado</span>
        <h1 class='title'>Solicitud de viaticos pendiente de desembolso</h1>
        <p class='muted'>La siguiente solicitud de viaticos fue aprobada y requiere procesamiento de pago al colaborador.</p>

        <div class='box'>
          <p class='box-title'>Datos del viatico</p>
          <div class='row'><strong>Solicitud:</strong> {{advanceDescription}}</div>
          {{#if projectLabel}}<div class='row'><strong>Centro de costo:</strong> {{projectLabel}}</div>{{/if}}
          {{#if viaticoStartDate}}<div class='row'><strong>Fecha de inicio:</strong> {{viaticoStartDate}}</div>{{/if}}
          {{#if viaticoEndDate}}<div class='row'><strong>Fecha de fin:</strong> {{viaticoEndDate}}</div>{{/if}}
          <div class='row'><strong>Colaborador:</strong> {{collaboratorName}}</div>
          {{#if collaboratorDni}}<div class='row'><strong>DNI:</strong> {{collaboratorDni}}</div>{{/if}}
          <div class='row'><strong>Monto solicitado:</strong></div>
          <div class='amount'>S/ {{budgetFormatted}}</div>
        </div>

        {{#if hasBankAccount}}
        <div class='box'>
          <p class='box-title'>Datos bancarios para deposito</p>
          <div class='row'><strong>Banco:</strong> {{bankName}}</div>
          <div class='row'><strong>Tipo de cuenta:</strong> {{accountType}}</div>
          <div class='row'><strong>N° de cuenta:</strong> {{accountNumber}}</div>
          {{#if cci}}<div class='row'><strong>CCI:</strong> {{cci}}</div>{{/if}}
        </div>
        {{else}}
        <div class='box'>
          <p class='box-title'>Datos bancarios para deposito</p>
          <p class='no-account'>El colaborador no tiene datos bancarios registrados en la plataforma.</p>
        </div>
        {{/if}}
      </div>
      <div class='footer'>&copy; {{year}} Viatika. Notificacion automatica.</div>
    </div>
  </div>
</body>
</html>
